# Azure/OpenAI realtime configuration
REALTIME_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-2
AZURE_OPENAI_REALTIME_API_VERSION=2025-04-01-preview
AZURE_OPENAI_API_KEY=replace-with-secret-value

# Firebase Admin credential for the bridge backend
FIREBASE_SERVICE_ACCOUNT_BASE64=replace-with-base64-service-account-json

# LiveKit server credentials
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

# Bridge auth secret
BRIDGE_JWT_SECRET=replace-with-shared-secret